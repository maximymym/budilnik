<Window x:Class="budilnik.AlarmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Alarm"
        Height="350"
        Width="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.Resources>
            <Style x:Key="RoundedButton" TargetType="Button">
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </Grid.Resources>
        <!-- Acrylic-like panel -->
        <Border CornerRadius="20"
                Padding="20"
                Background="#CCFFFFFF">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.3"/>
            </Border.Effect>
            <Grid>
                <!-- Header -->
                <Grid Margin="0,0,0,250">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Alarm"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="#333"
                               VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1"
                               FontFamily="Segoe MDL2 Assets"
                               Text=""
                               FontSize="24"
                               Foreground="#333"
                               Margin="10,0"
                               VerticalAlignment="Center"
                               Cursor="Hand"/>
                    <TextBlock Grid.Column="2"
                               FontFamily="Segoe MDL2 Assets"
                               Text=""
                               FontSize="24"
                               Foreground="#333"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Cursor="Hand"/>
                </Grid>
                <!-- Time display -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="AlarmTimeLabel"
                               Text="7:30 AM"
                               FontSize="80"
                               Foreground="#222"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="CountdownLabel"
                               Text="00:00:00"
                               FontSize="16"
                               Foreground="#666"
                               HorizontalAlignment="Center"
                               Margin="0,5,0,20"/>
                    <!-- New alarm button -->
                    <Button x:Name="NewAlarmButton"
                            Style="{StaticResource RoundedButton}"
                            Content="+ New alarm"
                            FontSize="16"
                            Padding="10,5"
                            Width="160"
                            Background="White"
                            Foreground="#333"
                            BorderBrush="#DDD"
                            BorderThickness="1"
                            Cursor="Hand"
                            Margin="0,0,0,30" Height="35"/>
                    <!-- Actions -->
                    <UniformGrid Columns="2" HorizontalAlignment="Center" Width="400">
                        <Button x:Name="SnoozeButton"
                                Style="{StaticResource RoundedButton}"
                                Content="Snooze"
                                FontSize="18"
                                Click ="SnoozeButton_Click"
                                Padding="10"
                                BorderThickness="0"
                                Background="#EEE"
                                Foreground="#222"
                                Cursor="Hand"
                                Margin="0,0,10,0" Height="35"/>
                        <Button x:Name="DismissButton"
                                Style="{StaticResource RoundedButton}"
                                Content="Dismiss"
                                Click="DismissButton_Click"
                                FontSize="18"
                                Padding="10"
                                BorderThickness="0"
                                Background="#EEE"
                                Foreground="#222"
                                Cursor="Hand"/>
                    </UniformGrid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>