<Window x:Class="budilnik.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:budilnik"
        Title="Alarm Setup"
        Width="400" Height="550"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    <Border CornerRadius="20" Background="#F8F8F8" Padding="20">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="10" Opacity="0.2"/>
        </Border.Effect>

        <StackPanel VerticalAlignment="Top" Margin="0">

            <!-- Заголовок -->
            <Grid>
                <TextBlock Text="Alarm"
                   FontFamily="Segoe UI Semibold"
                   FontSize="24"
                   VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center">
                    <TextBlock Text=""
                     FontFamily="Segoe MDL2 Assets"
                     FontSize="24"
                     Margin="0,0,10,0"/>
                    <TextBlock Text=""
                     FontFamily="Segoe MDL2 Assets"
                     FontSize="24"/>
                </StackPanel>
            </Grid>

            <!-- Колёсики для часов:минут:секунд -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0">
                <local:WheelPicker x:Name="HourPicker"/>
                <TextBlock Text=":" FontSize="48" VerticalAlignment="Center"/>
                <local:WheelPicker x:Name="MinutePicker"/>
                <TextBlock Text=":" FontSize="48" VerticalAlignment="Center"/>
                <local:WheelPicker x:Name="SecondPicker"/>
            </StackPanel>

            <!-- Отображение выбранного трека -->
            <TextBlock x:Name="SongTextBlock"
                 Text="Песня не выбрана"
                 FontFamily="Segoe UI"
                 FontSize="14"
                 HorizontalAlignment="Center"/>

            <!-- Кнопка выбора трека -->
            <Button x:Name="SelectSongButton"
              Content="Select Song…"
              FontFamily="Segoe UI"
              FontSize="16"
              Height="40"
              Click="SelectSongButton_Click"/>

            <!-- Кнопка установки будильника -->
            <Button x:Name="SetAlarmButton"
              Content="Set Alarm"
              FontFamily="Segoe UI"
              FontSize="16"
              Height="40"
              Click="SetAlarmButton_Click"/>

            <!-- Обратный отсчёт (если нужен здесь) -->
            <TextBlock x:Name="CountdownTextBlock"
                 Text=""
                 FontFamily="Segoe UI"
                 FontSize="14"
                 HorizontalAlignment="Center"/>

        </StackPanel>
    </Border>
</Window>
